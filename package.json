{
  "name": "soulpair",
  "version": "0.1.0",
  "private": true,
  "description": "Your AI finds your soulmate — AI Agent Dating Protocol on Monad",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "tsx apps/api/src/server.ts",
    "dev:web": "npm run dev -w apps/web",
    "test:e2e": "tsx test/e2e-flow.ts",
    "build:shared": "npm run build -w packages/shared",
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build:contracts": "npm run build -w packages/contracts",
    "test:contracts": "npm run test -w packages/contracts",
    "deploy:testnet": "npm run deploy:testnet -w packages/contracts"
  }
}
